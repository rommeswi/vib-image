[org/gnome/shell/extensions/unite]
enable-titlebar-actions=true
extend-left-box=false
greyscale-tray-icons=true
hide-activities-button='always'
hide-window-titlebars='always'
notifications-position='center'
reduce-panel-spacing=false
restrict-to-primary-screen=false
show-legacy-tray=true
show-window-buttons='always'
show-window-title='always'
use-activities-text=false
window-buttons-placement='left'
window-buttons-theme='qogir'

[org/gnome/shell/extensions/gtile]
grid-sizes='5x2'
auto-close=true
global-presets=false
moveresize-enabled=false
preset-resize-1=['1']
preset-resize-10=['<Shift>5']
preset-resize-11=['<Control>1']
preset-resize-12=['<Control>2']
preset-resize-13=['<Control>3']
preset-resize-14=['<Control>4']
preset-resize-15=['<Control>5']

[org/gnome/shell/extensions/burn-my-windows]
show-support-dialog=false
last-extension-version=39

[org/gnome/desktop/default-applications/terminal]
exec='kitty'
exec-arg=''
