[org/gnome/shell]
favorite-apps=['org.gnome.Nautilus.desktop', 'kitty.desktop', 'emacsclient.desktop']
enabled-extensions=['vso@vanillaos.org', 'system-monitor@gnome-shell-extensions.gcampax.github.com', 'drive-menu@gnome-shell-extensions.gcampax.github.com', 'screenshot-window-sizer@gnome-shell-extensions.gcampax.github.com', 'GPaste@gnome-shell-extensions.gnome.org', 'windowsNavigator@gnome-shell-extensions.gcampax.github.com', 'gsconnect@andyholmes.github.io', 'ddterm@amezin.github.com', 'gTile@vibou', 'burn-my-windows@schneegans.github.com', 'AlphabeticalAppGrid@stuarthayhurst', 'places-menu@gnome-shell-extensions.gcampax.github.com', 'apps-menu@gnome-shell-extensions.gcampax.github.com']

[org/gnome/desktop/background]
picture-uri='file:///usr/share/backgrounds/tokyonight.jpg'
picture-uri-dark='file:///usr/share/backgrounds/tokyonight.jpg'

[org/gnome/desktop/interface]
color-scheme='prefer-dark'
accent-color='slate'
enable-hot-corners=false
icon-theme='Colorful-Dark-Icons'

[org/gnome/desktop/peripherals/keyboard]
numlock-state=true

[org/gnome/nautilus/preferences]
default-folder-viewer='list-view'

[org/gnome/settings-daemon/plugins/power]
sleep-inactive-ac-timeout=uint32 7200
