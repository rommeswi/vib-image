FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# ── packages ──────────────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y \
    # core
    vim git meld openssh-client lshw curl wget jq unzip fontconfig \
    # shell
    zsh eza ranger cron bat zoxide \
    # editor/dev deps
    fzf ripgrep fd-find nodejs npm \
    # emacs + spacemacs pdf layer build deps
    emacs autoconf automake gcc libpng-dev make \
    libpoppler-dev libpoppler-glib-dev zlib1g-dev \
    # latex
    texlive-latex-base texlive-latex-recommended texlive-fonts-recommended \
    texlive-science texlive-latex-extra latexmk biber \
    # pdf viewer + annotator
    zathura zathura-pdf-poppler xournalpp \
    # zotero runtime dep
    libdbus-glib-1-2 \
    # python scientific stack
    python3-venv virtualenv python3-debugpy \
    python3-pylsp python3-pylsp-mypy python3-pylsp-rope \
    python3-pylsp-black python3-pylsp-isort python3-pylsp-jsonrpc \
    python3-diskcache python3-dask python3-dill \
    python3-scipy python3-numpy python3-pandas python3-jinja2 \
    python3-plotly python3-matplotlib python3-psycopg2 \
    && rm -rf /var/lib/apt/lists/*

# ── oh-my-posh ────────────────────────────────────────────────────────────────
RUN curl -s https://ohmyposh.dev/install.sh | bash -s -- -d /usr/local/bin \
    && mkdir -p /etc/skel/.config/oh-my-posh/themes \
    && cp -r /root/.cache/oh-my-posh/themes/. /etc/skel/.config/oh-my-posh/themes/

# ── shell dotfiles ────────────────────────────────────────────────────────────
COPY includes.container/shell/etc/skel/ /etc/skel/

# ── prezto ────────────────────────────────────────────────────────────────────
RUN git clone --recursive https://github.com/sorin-ionescu/prezto.git \
        /etc/skel/.config/zsh/.zprezto \
    && cd /etc/skel/.config/zsh/.zprezto \
    && git submodule add https://github.com/zpm-zsh/ls.git modules/ls \
    && git submodule add https://github.com/z-shell/zsh-eza.git \
    && git submodule add https://github.com/marlonrichert/zcolors.git modules/zcolors \
    && git submodule add https://github.com/Freed-Wu/zsh-help.git modules/zsh-help \
    && git submodule update --init --recursive \
    && git clone https://github.com/eza-community/eza-themes.git /tmp/eza-themes \
    && mkdir -p /etc/skel/.config/eza \
    && cp /tmp/eza-themes/themes/tokyonight.yml /etc/skel/.config/eza/theme.yml \
    && rm -rf /tmp/eza-themes

# ── neovim (arch-aware) ───────────────────────────────────────────────────────
ARG TARGETARCH
RUN NVIM_ARCH=$([ "$TARGETARCH" = "arm64" ] && echo "arm64" || echo "x86_64") \
    && curl -LO "https://github.com/neovim/neovim/releases/latest/download/nvim-linux-${NVIM_ARCH}.tar.gz" \
    && tar -C /tmp -xzf "nvim-linux-${NVIM_ARCH}.tar.gz" \
    && cp -r "/tmp/nvim-linux-${NVIM_ARCH}/bin/"* /usr/local/bin/ \
    && cp -r "/tmp/nvim-linux-${NVIM_ARCH}/lib/"* /usr/local/lib/ \
    && cp -r "/tmp/nvim-linux-${NVIM_ARCH}/share/"* /usr/local/share/ \
    && rm -rf "nvim-linux-${NVIM_ARCH}.tar.gz" "/tmp/nvim-linux-${NVIM_ARCH}"

# ── neovim dotfiles (lazyvim config now static in repo) ──────────────────────
COPY includes.container/neovim/etc/skel/ /etc/skel/

# ── spacemacs ─────────────────────────────────────────────────────────────────
RUN git clone https://github.com/syl20bnr/spacemacs /etc/skel/.emacs.d
COPY includes.container/spacemacs/etc/skel/ /etc/skel/

# ── python / uv (arch-aware) ──────────────────────────────────────────────────
ARG TARGETARCH
RUN UV_ARCH=$([ "$TARGETARCH" = "arm64" ] && echo "aarch64-unknown-linux-gnu" || echo "x86_64-unknown-linux-gnu") \
    && ln -s /usr/bin/python3 /usr/bin/python \
    && LATEST_RELEASE_URL=$(wget -qO - 'https://api.github.com/repos/astral-sh/uv/releases/latest' \
        | jq -r ".assets[] | select(.name==\"uv-${UV_ARCH}.tar.gz\") | .browser_download_url") \
    && wget -qO "uv-${UV_ARCH}.tar.gz" "$LATEST_RELEASE_URL" \
    && tar --strip-components=1 -xzf "uv-${UV_ARCH}.tar.gz" \
    && mv uv uvx /usr/local/bin/ \
    && rm "uv-${UV_ARCH}.tar.gz"

# ── jupyterlab + pip-only lsp plugins ────────────────────────────────────────
RUN uv pip install --system jupyterlab python-lsp-ruff

# ── zotero (arch-aware) ───────────────────────────────────────────────────────
RUN ZOTERO_ARCH=$([ "$TARGETARCH" = "arm64" ] && echo "linux-arm64" || echo "linux-x86_64") \
    && curl -fL "https://www.zotero.org/download/client/dl?channel=release&platform=${ZOTERO_ARCH}" \
       -o /tmp/zotero.tar.xz \
    && mkdir -p /opt/zotero \
    && tar -C /opt/zotero --strip-components=1 -xJf /tmp/zotero.tar.xz \
    && ln -s /opt/zotero/zotero /usr/local/bin/zotero \
    && rm /tmp/zotero.tar.xz

# ── jabref (arch-aware; arm64 .deb available from v6.0 stable onwards) ────────
RUN if [ "$TARGETARCH" = "arm64" ]; then \
      JABREF_JQ='.assets[] | select(.name | test("_arm64\\.deb$")) | .browser_download_url'; \
    else \
      JABREF_JQ='[.assets[] | select(.name | test("\\.deb$")) | select(.name | test("arm64") | not)] | .[0] | .browser_download_url'; \
    fi \
    && JABREF_URL=$(wget -qO - 'https://api.github.com/repos/JabRef/jabref/releases/latest' | jq -r "$JABREF_JQ") \
    && if [ -n "$JABREF_URL" ] && [ "$JABREF_URL" != "null" ]; then \
         wget -qO /tmp/jabref.deb "$JABREF_URL" \
         && apt-get install -y /tmp/jabref.deb \
         && rm /tmp/jabref.deb \
         && rm -rf /var/lib/apt/lists/*; \
       else \
         echo "JabRef: no Linux package for $TARGETARCH in this release — skipping."; \
       fi

# ── vib-tip ───────────────────────────────────────────────────────────────────
COPY includes.container/usr/local/bin/vib-tip /usr/local/bin/vib-tip
COPY includes.container/usr/local/share/vib/ /usr/local/share/vib/

# ── nerd fonts ────────────────────────────────────────────────────────────────
RUN mkdir -p /usr/local/share/fonts /nerdfonts
COPY includes.container/nerdfonts/nerdfont-install.sh /tmp/nerdfont-install.sh
RUN bash /tmp/nerdfont-install.sh && rm /tmp/nerdfont-install.sh

# ── claude code ───────────────────────────────────────────────────────────────
RUN npm install -g @anthropic-ai/claude-code

# ── create user ───────────────────────────────────────────────────────────────
RUN useradd -m -s /usr/bin/zsh -U lab

WORKDIR /home/lab
USER lab

CMD ["/usr/bin/zsh"]
